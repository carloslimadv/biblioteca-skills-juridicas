---
import '../styles/global.css';
import { categories, installCommands, repository, skills } from '../data/skills';

const totalSkills = skills.length;
const categoryCounts = skills.reduce<Record<string, number>>((acc, skill) => {
  acc[skill.category] = (acc[skill.category] ?? 0) + 1;
  return acc;
}, {});
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const heroImage = 'https://images.unsplash.com/photo-1450101499163-c8848c66ca85?auto=format&fit=crop&w=1600&q=84';
const rawBase = `${repository.url}/tree/main/skills`;
const instagramUrl = 'https://www.instagram.com/carloslimadv/';
const donationUrl = 'https://www.buymeacoffee.com/carloslimadv';
const featuredSkills = skills.slice(0, 4);
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Biblioteca pública de skills jurídicas para Codex, Claude Code e outras LLMs, com instalação via npx skills e documentação didática para advogados."
    />
    <meta property="og:title" content="Biblioteca Skills Jurídicas" />
    <meta property="og:description" content="Skills jurídicas para Codex e Claude Code, com instalação simples e uso responsável na advocacia brasileira." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={repository.pagesUrl} />
    <meta property="og:image" content={heroImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#0b0f12" />
    <link rel="canonical" href={repository.pagesUrl} />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <title>Biblioteca Skills Jurídicas</title>
  </head>
  <body>
    <header class="topbar" aria-label="Cabeçalho principal">
      <a class="brand" href="#topo" aria-label="Biblioteca Skills Jurídicas">
        <span class="brand-mark" aria-hidden="true">§</span>
        <span>
          <strong>Skills Jurídicas</strong>
          <small>repositório público</small>
        </span>
      </a>

      <nav class="nav" aria-label="Navegação principal">
        <a href="#instalacao">Instalar</a>
        <a href="#catalogo">Catálogo</a>
        <a href="#uso">Responsabilidade</a>
        <a href={repository.url} target="_blank" rel="noopener noreferrer">GitHub</a>
      </nav>

      <div class="header-tools">
        <a class="icon-link" href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram de Carlos Lima">
          <svg aria-hidden="true" viewBox="0 0 24 24" focusable="false">
            <rect x="3" y="3" width="18" height="18" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1"></circle>
          </svg>
          <span>Instagram</span>
        </a>
        <div class="donation-slot" aria-label="Apoie este projeto">
          <script
            is:inline
            type="text/javascript"
            src="https://cdnjs.buymeacoffee.com/1.0.0/button.prod.min.js"
            data-name="bmc-button"
            data-slug="carloslimadv"
            data-color="#FFDD00"
            data-emoji="☕"
            data-font="Bree"
            data-text="Compre-me um café"
            data-outline-color="#000000"
            data-font-color="#000000"
            data-coffee-color="#ffffff"
          ></script>
          <noscript>
            <a class="donation-fallback" href={donationUrl} target="_blank" rel="noopener noreferrer">
              Compre-me um café
            </a>
          </noscript>
        </div>
      </div>
    </header>

    <main id="topo">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Skills jurídicas para advogados</p>
            <h1 id="hero-title">Instale skills jurídicas no Codex ou Claude.</h1>
            <p class="hero-lead">
              Um conjunto público de {totalSkills} skills para ajudar no trabalho com petições, provas, contratos, jurisprudência, marketing jurídico, PDFs e revisão. Tudo explicado em linguagem simples, com comando para instalar e opção de baixar cada skill separadamente.
            </p>
          </div>

          <aside class="install-console" aria-label="Comando principal de instalação">
            <div class="console-top">
              <span>comando principal</span>
              <span>Codex, Claude e outros</span>
            </div>
            <code>{installCommands.codex}</code>
            <button class="copy-button console-copy" type="button" data-copy={installCommands.codex}>Copiar comando</button>
          </aside>
        </div>
      </section>

      <section class="install-section" id="instalacao" aria-labelledby="install-title">
        <div class="section-rail">
          <p class="eyebrow">Instalação simplificada</p>
          <h2 id="install-title">Um comando para instalar.</h2>
          <p>
            O instalador baixa o repositório pelo GitHub e detecta o ambiente disponível. Em ferramentas que mostram seleção, escolha Codex, Claude Code ou a opção equivalente.
          </p>
        </div>

        <div class="command-stack">
          <article class="command-panel main-command">
            <div class="panel-label">
              <span>01</span>
              <strong>Instalar todas as skills</strong>
            </div>
            <p>Opção recomendada para começar. Copie, cole no terminal e siga as opções do instalador, se aparecerem.</p>
            <div class="command-row">
              <code>{installCommands.codex}</code>
              <button class="copy-button" type="button" data-copy={installCommands.codex}>Copiar</button>
            </div>
          </article>

          <article class="command-panel">
            <div class="panel-label">
              <span>02</span>
              <strong>Ver antes de instalar</strong>
            </div>
            <p>Mostra a lista de skills disponíveis no repositório.</p>
            <div class="command-row">
              <code>{installCommands.list}</code>
              <button class="copy-button" type="button" data-copy={installCommands.list}>Copiar</button>
            </div>
          </article>

          <article class="command-panel">
            <div class="panel-label">
              <span>03</span>
              <strong>Instalar uma skill específica</strong>
            </div>
            <p>Use quando quiser baixar apenas uma rotina, como Petição Completa.</p>
            <div class="command-row">
              <code>{skills[0].installCommand}</code>
              <button class="copy-button" type="button" data-copy={skills[0].installCommand}>Copiar</button>
            </div>
          </article>
        </div>
      </section>

      <section class="operating-model" aria-labelledby="model-title">
        <div class="model-copy">
          <p class="eyebrow">Como pensar o uso</p>
          <h2 id="model-title">A skill é um jeito organizado de pedir trabalho à IA.</h2>
        </div>
        <div class="model-grid">
          <article>
            <span>entrada</span>
            <h3>Contexto e documentos</h3>
            <p>O usuário entrega peça, prova, tese, contrato, briefing ou pasta de arquivos.</p>
          </article>
          <article>
            <span>método</span>
            <h3>SKILL.md</h3>
            <p>A skill define quando agir, como separar fato de inferência, quais limites respeitar e qual saída produzir.</p>
          </article>
          <article>
            <span>saída</span>
            <h3>Material revisável</h3>
            <p>O resultado é uma minuta, análise, mapa, checklist ou orientação prática para revisão humana.</p>
          </article>
        </div>
      </section>

      <section class="catalog-section" id="catalogo" aria-labelledby="catalog-title">
        <aside class="catalog-controls" aria-label="Filtros do catálogo">
          <p class="eyebrow">Catálogo vivo</p>
          <h2 id="catalog-title">{totalSkills} skills para baixar, auditar e instalar.</h2>

          <label class="search-box">
            <span>Buscar</span>
            <input id="skill-search" type="search" placeholder="petição, contrato, prova, PDF..." autocomplete="off" />
          </label>

          <div class="filter-list" role="group" aria-label="Filtros por finalidade">
            {
              categories.map((category) => (
                <button
                  type="button"
                  class="filter-chip"
                  data-filter={category.id}
                  aria-pressed={category.id === 'all' ? 'true' : 'false'}
                >
                  <span>{category.label}</span>
                  <small>{category.id === 'all' ? totalSkills : categoryCounts[category.id] ?? 0}</small>
                </button>
              ))
            }
          </div>

          <p class="results-count" id="results-count" aria-live="polite">{totalSkills} skills encontradas</p>

          <div class="featured-docket" aria-label="Skills em destaque">
            {
              featuredSkills.map((skill, index) => (
                <a href={`#skill-${skill.id}`}>
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{skill.title}</strong>
                </a>
              ))
            }
          </div>
        </aside>

        <div class="skill-list" id="skill-list">
          {
            skills.map((skill, index) => (
              <article
                class="skill-card"
                id={`skill-${skill.id}`}
                data-category={skill.category}
                data-search={`${skill.title} ${skill.name} ${skill.categoryLabel} ${skill.summary} ${skill.serves} ${skill.whenToUse.join(' ')} ${skill.bestUse}`}
              >
                <details>
                  <summary>
                    <span class="skill-index">{String(index + 1).padStart(2, '0')}</span>
                    <span class="summary-copy">
                      <span class="meta-line">
                        <span>{skill.categoryLabel}</span>
                        <span>risco {skill.risk}</span>
                        <span>{skill.trigger}</span>
                      </span>
                      <strong>{skill.title}</strong>
                      <em>{skill.summary}</em>
                    </span>
                    <span class="open-indicator" aria-hidden="true">Abrir</span>
                  </summary>

                  <div class="skill-detail">
                    <section>
                      <h3>Para que serve</h3>
                      <p>{skill.serves}</p>
                    </section>
                    <section>
                      <h3>Quando usar</h3>
                      <ul>
                        {skill.whenToUse.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>
                    <section>
                      <h3>Quando não usar</h3>
                      <ul>
                        {skill.whenNotToUse.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>
                    <section>
                      <h3>Como funciona</h3>
                      <ul>
                        {skill.howItWorks.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>
                    <section class="wide">
                      <h3>Melhor forma de uso</h3>
                      <p>{skill.bestUse}</p>
                    </section>
                    <section>
                      <h3>Limites</h3>
                      <ul>
                        {skill.limitations.map((item) => <li>{item}</li>)}
                      </ul>
                    </section>
                    <section class="wide">
                      <h3>Instalar só esta skill</h3>
                      <div class="command-row">
                        <code>{skill.installCommand}</code>
                        <button class="copy-button" type="button" data-copy={skill.installCommand}>Copiar</button>
                      </div>
                    </section>
                    <section>
                      <h3>Uso no Codex</h3>
                      <p><code>{skill.codexPrompt}</code></p>
                    </section>
                    <section>
                      <h3>Uso no Claude</h3>
                      <p><code>{skill.claudePrompt}</code></p>
                    </section>
                    <section class="wide">
                      <h3>Arquivos principais</h3>
                      <p>{skill.files.join(' · ')}</p>
                      <div class="card-actions">
                        <a class="button small-button" href={`${rawBase}/${skill.folder}`} target="_blank" rel="noopener noreferrer">Abrir pasta</a>
                        <a class="button small-button" href={`${baseUrl}downloads/${skill.folder}.zip`} download>Baixar ZIP</a>
                      </div>
                    </section>
                  </div>
                </details>
              </article>
            ))
          }
        </div>
      </section>

      <section class="responsibility-section" id="uso" aria-labelledby="usage-title">
        <div class="section-rail">
          <p class="eyebrow">Uso responsável</p>
          <h2 id="usage-title">A skill melhora o método. A responsabilidade continua sendo do advogado.</h2>
        </div>
        <div class="responsibility-grid">
          <article>
            <span>01</span>
            <h3>Fatos</h3>
            <p>Não use IA para completar datas, valores, números de processo, documentos ou histórico do cliente.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Fontes</h3>
            <p>Lei, jurisprudência, OAB, políticas de plataforma e dados atuais devem ser conferidos antes do uso profissional.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Sigilo</h3>
            <p>Anonimize material sensível sempre que possível e observe sigilo profissional, LGPD e regras da ferramenta usada.</p>
          </article>
          <article>
            <span>04</span>
            <h3>Revisão</h3>
            <p>Peças, contratos, pareceres, marketing e documentos finais precisam de revisão humana antes de envio ou protocolo.</p>
          </article>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <span class="footer-label">Biblioteca Skills Jurídicas</span>
          <p>Projeto público para uso responsável de IA na advocacia brasileira.</p>
        </div>
        <div class="footer-links">
          <a href={`${repository.url}/blob/main/INSTALL.md`} target="_blank" rel="noopener noreferrer">Instalação</a>
          <a href={`${repository.url}/blob/main/docs/codex.md`} target="_blank" rel="noopener noreferrer">Codex</a>
          <a href={`${repository.url}/blob/main/docs/claude.md`} target="_blank" rel="noopener noreferrer">Claude</a>
        </div>
      </div>
      <div class="footer-repo">
        <span>Repositório do projeto</span>
        <a href={repository.url} target="_blank" rel="noopener noreferrer">{repository.url}</a>
      </div>
    </footer>

    <script is:inline>
      const searchInput = document.querySelector('#skill-search');
      const cards = Array.from(document.querySelectorAll('.skill-card'));
      const filterButtons = Array.from(document.querySelectorAll('[data-filter]'));
      const count = document.querySelector('#results-count');
      let activeFilter = 'all';

      const normalize = (value) =>
        value
          .toLowerCase()
          .normalize('NFD')
          .replace(/[\u0300-\u036f]/g, '');

      const applyFilters = () => {
        const query = normalize(searchInput?.value ?? '');
        let visible = 0;
        cards.forEach((card) => {
          const matchesFilter = activeFilter === 'all' || card.dataset.category === activeFilter;
          const matchesSearch = normalize(card.dataset.search ?? '').includes(query);
          const shouldShow = matchesFilter && matchesSearch;
          card.hidden = !shouldShow;
          if (shouldShow) visible += 1;
        });
        if (count) count.textContent = `${visible} ${visible === 1 ? 'skill encontrada' : 'skills encontradas'}`;
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeFilter = button.dataset.filter ?? 'all';
          filterButtons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
          applyFilters();
        });
      });

      searchInput?.addEventListener('input', applyFilters);

      document.querySelectorAll('.copy-button').forEach((button) => {
        button.addEventListener('click', async () => {
          const value = button.getAttribute('data-copy') ?? '';
          const fallbackCopy = () => {
            const area = document.createElement('textarea');
            area.value = value;
            area.setAttribute('readonly', '');
            area.style.position = 'fixed';
            area.style.left = '-9999px';
            document.body.appendChild(area);
            area.select();
            const copied = document.execCommand('copy');
            area.remove();
            return copied;
          };
          try {
            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(value);
            } else if (!fallbackCopy()) {
              throw new Error('copy failed');
            }
            const previous = button.textContent;
            button.textContent = 'Copiado';
            window.setTimeout(() => {
              button.textContent = previous;
            }, 1300);
          } catch {
            if (fallbackCopy()) {
              const previous = button.textContent;
              button.textContent = 'Copiado';
              window.setTimeout(() => {
                button.textContent = previous;
              }, 1300);
            } else {
              button.textContent = 'Selecione';
            }
          }
        });
      });
    </script>
  </body>
</html>
